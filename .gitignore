# Ignore video files
*.mp4
*.mkv
*.avi
*.mov
*.flv
*.wmv

# Ignore Python bytecode
__pycache__/
*.pyc

# Ignore output subtitles (keep them out of git if desired)
# *.txt

# Ignore git worktrees
.worktrees/
worktrees/

# Ignore embedded Python (too large for git - download separately)
python/

# Gradle build files
.gradle/
gui/build/
gui/.gradle/

# Package build outputs
*.exe
*.msi
*.dmg
*.deb

# Logs and temp files
*.log
gui/logs/
logs/
backend.log

# FFmpeg DLLs (should be in ffmpeg directory)
*.dll

# Run scripts
run_gui.bat
run_output*.log
run_test.ps1
test_path.kts
